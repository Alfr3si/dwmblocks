#!/bin/bash
icon() {
    [ "$1" -lt 15 ] && printf "яЙД" && exit
    [ "$1" -lt 35 ] && printf "яЙГ" && exit
    [ "$1" -lt 60 ] && printf "яЙВ" && exit
    [ "$1" -lt 80 ] && printf "яЙБ" && exit
    printf "яЙА"
}

IC_CURRENT="яЗж"
IC_PLUG="ґ░Ъж"
acpi > /tmp/acpi_info

while read line; do
  percent="$(echo "$line" | awk -F ', ' '{print $2}' | sed 's/.$//')"

    #Battery Down 
  if echo "$line" | grep  "Discharging," > /dev/null; then 
    if [ $percent -lt 16 ]; then
      printf "^c#fe624d^$(icon "$percent") "
      printf "$percent%%^d^ " &&
      notify-send -u critical -t 5000 "Battery Low ЁЯФЛ" "Connect please"
    elif [ $percent -lt 31 ]; then
      printf "^c#e8e66e^$(icon "$percent") "
      printf "$percent%%^d^ "
    else
      printf "$(icon "$percent") "
      printf "$percent%% "
    fi
    #Battery Full
  elif echo "$line" | grep "Full" > /dev/null; then
    printf "^c#fe213b^$IC_PLUG 100%%^d^ " &&
    notify-send "Battery Full ЁЯФЛ" "Disconnect please"
    #Charging
  elif ! echo "$line" | grep "Unknown" > /dev/null; then
    if [ $percent -eq 100 ]; then
       printf "^c#fe213b^$IC_PLUG 100%%^d^ "
    else
	printf "^c#a7fe21^$IC_CURRENT $percent%%^d^ "
    fi
  fi
done < /tmp/acpi_info
