#!/bin/bash

vol(){
  pamixer --get-volume
}

str(){
  echo "$1"
}

case $BLOCK_BUTTON in
    1) pamixer -t ;;
    4) pamixer -i 2;; 
    5) pamixer -d 2;;
esac

if [ "$(pamixer --get-mute)" = "true" ]; then
  str " ´Çğ ´üŞ "
  exit 0
fi

v=$(vol)
if [ "$v" -eq "100" ]; then
  str " ´Ç¿ 100% "
elif [ "$v" -ge "30" ]; then
  str " ´Çğ $v% "
else 
  str " ´ÇĞ $v% "
fi
